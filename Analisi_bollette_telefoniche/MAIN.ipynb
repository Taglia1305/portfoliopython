# --- Telecommunications Traffic Analysis Main Script ---

def data_ingestion(file_path):
    """
    Loads raw data from the source file.
    """
    raw_records = []
    try:
        with open(file_path, 'r') as file:
            for line in file:
                # Maintains your original structure for data parsing
                raw_records.append(line.strip().split(','))
        print(f"Successfully loaded {len(raw_records)} records.")
    except FileNotFoundError:
        print("Error: Source file not found.")
    return raw_records

def process_billing(records, rate_per_second, threshold):
    """
    Main logic for calculating subscriber bills and applying bonuses.
    """
    subscriber_totals = {}
    
    for entry in records:
        # Mapping your variables to professional English
        subscriber_id = entry[0]
        duration = float(entry[1])
        
        if subscriber_id not in subscriber_totals:
            subscriber_totals[subscriber_id] = 0.0
            
        # Calculation logic
        total_cost = duration * rate_per_second
        subscriber_totals[subscriber_id] += total_cost
        
    # Bonus and Discount application
    final_invoices = {}
    for subscriber, amount in subscriber_totals.items():
        if amount > threshold:
            # Applying a professional discount logic as per your original structure
            final_invoices[subscriber] = amount * 0.85 
        else:
            final_invoices[subscriber] = amount
            
    return final_invoices

def analyze_cell_traffic(records):
    """
    Identifies network congestion and traffic distribution per cell.
    """
    cell_usage = {}
    for entry in records:
        cell_id = entry[2]
        if cell_id not in cell_usage:
            cell_usage[cell_id] = 1
        else:
            cell_usage[cell_id] += 1
    return cell_usage

def save_report(results, output_path):
    """
    Exports the processed data to the designated output file.
    """
    with open(output_path, 'w') as file:
        file.write("Subscriber_ID,Total_Bill\n")
        for subscriber, bill in results.items():
            file.write(f"{subscriber},{bill:.2f}\n")
    print(f"Report successfully saved to: {output_path}")

# --- Main Execution Flow ---
if __name__ == "__main__":
    # Configuration constants
    INPUT_DATA = "data/raw_traffic_logs.txt"
    OUTPUT_REPORT = "data/billing_report.csv"
    RATE = 0.002
    BONUS_LIMIT = 50.0

    print("--- Starting Telecommunications Analysis Pipeline ---")
    
    # 1. Ingestion
    data = data_ingestion(INPUT_DATA)
    
    # 2. Processing & Billing
    if data:
        processed_bills = process_billing(data, RATE, BONUS_LIMIT)
        
        # 3. Network Analysis
        congestion_data = analyze_cell_traffic(data)
        
        # 4. Export
        save_report(processed_bills, OUTPUT_REPORT)
        
    print("--- Analysis Completed Successfully ---")
